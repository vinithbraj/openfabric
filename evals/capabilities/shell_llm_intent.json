{
  "capability": "shell_llm_intent",
  "strict_threshold": 0.9,
  "semantic_threshold": 1.0,
  "max_llm_fallbacks": 12,
  "cases": [
    {
      "id": "shell_llm_uptime_text",
      "prompt": "check uptime",
      "expected_regex": "load average",
      "expect_llm_calls": 1,
      "category": "uptime",
      "setup": {"expected_raw_planner_llm_calls": 0}
    },
    {
      "id": "shell_llm_disk_usage_text",
      "prompt": "show disk usage",
      "expected_regex": "Filesystem",
      "expect_llm_calls": 1,
      "category": "disk_usage",
      "setup": {"expected_raw_planner_llm_calls": 0}
    },
    {
      "id": "shell_llm_memory_summary_text",
      "prompt": "show memory usage",
      "expected_regex": "Mem:",
      "expect_llm_calls": 1,
      "category": "memory_summary",
      "setup": {"expected_raw_planner_llm_calls": 0}
    },
    {
      "id": "shell_llm_process_summary_text",
      "prompt": "show top processes",
      "expected_regex": "PID\\s+USER\\s+COMMAND\\s+%CPU\\s+%MEM",
      "expect_llm_calls": 1,
      "category": "process_summary",
      "setup": {"expected_raw_planner_llm_calls": 0}
    },
    {
      "id": "shell_llm_network_summary_text",
      "prompt": "show network summary",
      "expected_regex": "\\binet\\b",
      "expect_llm_calls": 1,
      "category": "network_summary",
      "setup": {"expected_raw_planner_llm_calls": 0}
    },
    {
      "id": "shell_llm_listening_ports_text",
      "prompt": "show listening ports",
      "expected_regex": "Netid",
      "expect_llm_calls": 1,
      "category": "listening_ports",
      "setup": {"expected_raw_planner_llm_calls": 0}
    },
    {
      "id": "shell_llm_file_aggregate_text",
      "prompt": "using shell, how much space do mp4s take under {files_lambda}",
      "expected": "3 files, 11 bytes",
      "expect_llm_calls": 1,
      "category": "file_aggregate",
      "setup": {"expected_raw_planner_llm_calls": 0}
    },
    {
      "id": "shell_llm_content_files_json",
      "prompt": "with shell, show files containing cinnamon under {search_pantry} as json",
      "expected_contains": ["\"matches\":", "\"cake.txt\"", "\"notes.md\"", "\"tea.txt\""],
      "expect_llm_calls": 1,
      "category": "content_files",
      "setup": {"expected_raw_planner_llm_calls": 0}
    },
    {
      "id": "shell_llm_content_lines_json",
      "prompt": "with shell, show matching lines containing cinnamon under {search_pantry} as json",
      "expected_contains": ["\"rows\":", "\"path\": \"cake.txt\"", "\"path\": \"notes.md\"", "\"text\": \"cinnamon sugar\""],
      "expect_llm_calls": 1,
      "category": "content_lines",
      "setup": {"expected_raw_planner_llm_calls": 0}
    },
    {
      "id": "shell_llm_fetch_title_text",
      "prompt": "fetch the title of {fetch_example} using shell",
      "expected": "Example Fixture",
      "expect_llm_calls": 1,
      "category": "fetch_title",
      "setup": {"expected_raw_planner_llm_calls": 0}
    },
    {
      "id": "shell_llm_delete_rejected",
      "prompt": "delete all logs",
      "expected_contains": ["read-only shell/system inspection only", "Unsupported request: delete"],
      "expect_llm_calls": 0,
      "category": "mutation_rejected",
      "setup": {"expected_raw_planner_llm_calls": 0}
    },
    {
      "id": "shell_llm_kill_rejected",
      "prompt": "kill process 123",
      "expected_contains": ["read-only shell/system inspection only", "Unsupported request: kill"],
      "expect_llm_calls": 0,
      "category": "mutation_rejected",
      "setup": {"expected_raw_planner_llm_calls": 0}
    }
  ]
}
