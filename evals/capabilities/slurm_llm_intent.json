{
  "capability": "slurm_llm_intent",
  "strict_threshold": 0.9,
  "semantic_threshold": 1.0,
  "max_llm_fallbacks": 10,
  "cases": [
    {
      "id": "slurm_llm_cluster_busy_json",
      "prompt": "Is the cluster busy right now?",
      "expected_contains": ["\"queue_count\": 4", "\"running_jobs\": 2", "\"pending_jobs\": 2"],
      "expect_llm_calls": 1,
      "category": "cluster_busy",
      "setup": {"expected_raw_planner_llm_calls": 0}
    },
    {
      "id": "slurm_llm_gpu_availability_json",
      "prompt": "Are GPUs available?",
      "expected_contains": ["\"nodes_with_gpu\": 3", "\"total_gpus\": 9", "\"gpu:a100:4\": 2", "\"gpu:v100:1\": 1"],
      "expect_llm_calls": 1,
      "category": "gpu_availability",
      "setup": {"expected_raw_planner_llm_calls": 0}
    },
    {
      "id": "slurm_llm_scheduler_health_json",
      "prompt": "What is going on with the scheduler?",
      "expected_contains": ["\"job_count\": 4", "\"RUNNING\": 2", "\"PENDING\": 2"],
      "expect_llm_calls": 1,
      "category": "scheduler_health",
      "setup": {"expected_raw_planner_llm_calls": 0}
    },
    {
      "id": "slurm_llm_stuck_jobs_json",
      "prompt": "Are my jobs stuck?",
      "expected_contains": ["\"jobs\":", "\"job_id\": \"12347\"", "\"user\": \"{current_user}\"", "\"state\": \"PENDING\""],
      "expect_llm_calls": 1,
      "category": "stuck_jobs",
      "setup": {"expected_raw_planner_llm_calls": 0}
    },
    {
      "id": "slurm_llm_failed_recently_json",
      "prompt": "What failed recently?",
      "expected_contains": ["\"jobs\":", "\"job_id\": \"12341\"", "\"state\": \"FAILED\""],
      "expect_llm_calls": 1,
      "category": "failed_recently",
      "setup": {"expected_raw_planner_llm_calls": 0}
    },
    {
      "id": "slurm_llm_jobs_yesterday_json",
      "prompt": "How did jobs do yesterday?",
      "expected_contains": ["\"jobs\":", "\"job_id\": \"12340\"", "\"job_id\": \"12341\""],
      "expect_llm_calls": 1,
      "category": "jobs_yesterday",
      "setup": {"expected_raw_planner_llm_calls": 0}
    },
    {
      "id": "slurm_llm_unhealthy_nodes_json",
      "prompt": "Show me anything unhealthy in SLURM.",
      "expected_contains": ["\"nodes\":", "\"name\": \"slurm-worker-delta\"", "\"state\": \"down\""],
      "expect_llm_calls": 1,
      "category": "node_problems",
      "setup": {"expected_raw_planner_llm_calls": 0}
    },
    {
      "id": "slurm_llm_partition_pressure_json",
      "prompt": "How much pressure are the partitions under?",
      "expected_contains": ["\"partitions\":", "\"partition\": \"gpu\"", "\"partition\": \"cpu\""],
      "expect_llm_calls": 1,
      "category": "partition_pressure",
      "setup": {"expected_raw_planner_llm_calls": 0}
    },
    {
      "id": "slurm_llm_slurmdbd_health_json",
      "prompt": "Is slurmdbd healthy?",
      "expected_contains": ["\"available\": true", "\"status\": \"ok\"", "\"clusterA|controlhost\""],
      "expect_llm_calls": 1,
      "category": "slurmdbd_health",
      "setup": {"expected_raw_planner_llm_calls": 0}
    },
    {
      "id": "slurm_llm_mutation_rejected",
      "prompt": "Cancel my job 123",
      "expected_contains": ["read-only SLURM inspection and metrics only", "Unsupported operation"],
      "expect_llm_calls": 0,
      "category": "mutation_rejected",
      "setup": {"expected_raw_planner_llm_calls": 0}
    }
  ]
}
